-  try {
-    const { key: apiKey } = getAnthropicApiKeyWithSource({
-      skipRetrievingKeyFromApiKeyHelper: true,
-    })
-    if (apiKey) {
-      return (cached = setEligibility(true))
-    }
-  } catch {
-    // No API key available (e.g., CI/test environment)
-  }
-
-  return (cached = setEligibility(false))
