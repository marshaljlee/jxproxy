{
  "name": "jxproxy",
  "version": "0.1.0",
  "description": "Proxy-routed Claude Code — telemetry stripped, guardrails removed, all features unlocked, zero callbacks home.",
  "type": "module",
  "bin": {
    "jxproxy": "./dist/jxproxy"
  },
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "build": "bun run scripts/build.ts",
    "build:proxy": "bun build ./proxy/server.ts --compile --target bun --outfile ./dist/jxproxy-proxy",
    "build:all": "bun run build && bun run build:proxy",
    "dev": "bun run scripts/build.ts --dev",
    "patch": "bash scripts/patch-source.sh",
    "clean": "rm -rf dist src .source"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.8.0"
  }
}
