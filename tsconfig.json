{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@ant/computer-use-mcp": ["./stubs/@ant/computer-use-mcp/index.ts"],
      "@ant/computer-use-mcp/types": ["./stubs/@ant/computer-use-mcp/types/index.ts"],
      "@ant/computer-use-mcp/sentinelApps": ["./stubs/@ant/computer-use-mcp/sentinelApps/index.ts"],
      "@ant/computer-use-input": ["./stubs/@ant/computer-use-input/index.ts"],
      "@ant/computer-use-swift": ["./stubs/@ant/computer-use-swift/index.ts"],
      "@ant/claude-for-chrome-mcp": ["./stubs/@ant/claude-for-chrome-mcp/index.ts"]
    },
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "proxy/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", ".source"]
}
